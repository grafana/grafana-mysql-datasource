{
    "$schema": "https://raw.githubusercontent.com/grafana/dsconfig/refs/heads/main/dsconfig/schema.json",
    "schemaVersion": "v1",
    "pluginType": "mysql",
    "pluginName": "MySQL",
    "docURL": "https://grafana.com/docs/grafana/latest/datasources/mysql/",
    "fields": [
        {
            "id": "root.url",
            "key": "url",
            "label": "Host URL",
            "description": "MySQL host and port.",
            "valueType": "string",
            "target": "root",
            "required": true,
            "ui": {
                "component": "input",
                "placeholder": "localhost:3306"
            }
        },
        {
            "id": "jsonData.database",
            "key": "database",
            "label": "Database name",
            "description": "MySQL database name.",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "Database"
            }
        },
        {
            "id": "root.user",
            "key": "user",
            "label": "Username",
            "description": "Database username.",
            "valueType": "string",
            "target": "root",
            "required": true,
            "ui": {
                "component": "input",
                "placeholder": "Username"
            }
        },
        {
            "id": "secureJsonData.password",
            "key": "password",
            "label": "Password",
            "description": "Database password.",
            "valueType": "string",
            "semanticType": "password",
            "target": "secureJsonData"
        },
        {
            "id": "jsonData.allowCleartextPasswords",
            "key": "allowCleartextPasswords",
            "label": "Allow Cleartext Passwords",
            "description": "Allows using the cleartext client side plugin if required by an account.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.tlsSkipVerify",
            "key": "tlsSkipVerify",
            "label": "Skip TLS Verification",
            "description": "When enabled, skips verification of the MySQL server's TLS certificate chain and host name.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.tlsConfigurationMethod",
            "key": "tlsConfigurationMethod",
            "label": "TLS configuration method",
            "description": "How the TLS certificates are configured: as file paths on disk or as file contents in secure JSON data.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.sslmode",
            "key": "sslmode",
            "label": "SSL mode",
            "description": "Determines whether and with what priority a secure SSL TCP/IP connection is negotiated with the server.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.sslRootCertFile",
            "key": "sslRootCertFile",
            "label": "TLS/SSL Root Certificate file path",
            "description": "Path to the PEM-encoded CA certificate file used to verify the server certificate.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.sslCertFile",
            "key": "sslCertFile",
            "label": "TLS/SSL Client Certificate file path",
            "description": "Path to the PEM-encoded client certificate file used for TLS client authentication.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.sslKeyFile",
            "key": "sslKeyFile",
            "label": "TLS/SSL Client Key file path",
            "description": "Path to the PEM-encoded client private key file used for TLS client authentication.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.servername",
            "key": "servername",
            "label": "TLS/SSL Server name",
            "description": "Server name used to verify the hostname on the returned TLS certificate.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.encrypt",
            "key": "encrypt",
            "label": "Encrypt",
            "description": "Determines whether or how the connection to the server is encrypted.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.timescaledb",
            "key": "timescaledb",
            "label": "TimescaleDB",
            "description": "Enables TimescaleDB-specific features and query support.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.authenticationType",
            "key": "authenticationType",
            "label": "Authentication type",
            "description": "The authentication method used to connect to the database.",
            "valueType": "string",
            "target": "jsonData"
        },
        {
            "id": "jsonData.timezone",
            "key": "timezone",
            "label": "Session timezone",
            "description": "Specify the timezone used in the database session, such as Europe/Berlin or +02:00.",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "Europe/Berlin or +02:00"
            }
        },
        {
            "id": "jsonData.timeInterval",
            "key": "timeInterval",
            "label": "Min time interval",
            "description": "A lower limit for the auto group by time interval. Recommended to be set to write frequency, for example 1m if your data is written every minute.",
            "valueType": "string",
            "semanticType": "duration",
            "target": "jsonData",
            "ui": {
                "component": "input",
                "placeholder": "1m"
            }
        },
        {
            "id": "jsonData.maxOpenConns",
            "key": "maxOpenConns",
            "label": "Max open",
            "description": "Maximum number of open connections to the database.",
            "valueType": "number",
            "target": "jsonData",
            "validations": [
                {
                    "type": "range",
                    "min": 0
                }
            ]
        },
        {
            "id": "jsonData.maxIdleConns",
            "key": "maxIdleConns",
            "label": "Max idle",
            "description": "Maximum number of idle connections in the connection pool.",
            "valueType": "number",
            "target": "jsonData",
            "validations": [
                {
                    "type": "range",
                    "min": 0
                }
            ]
        },
        {
            "id": "jsonData.connMaxLifetime",
            "key": "connMaxLifetime",
            "label": "Max lifetime",
            "description": "Maximum amount of time in seconds a connection may be reused.",
            "valueType": "number",
            "target": "jsonData",
            "validations": [
                {
                    "type": "range",
                    "min": 0
                }
            ]
        },
        {
            "id": "jsonData.connectionTimeout",
            "key": "connectionTimeout",
            "label": "Connection timeout",
            "description": "The number of seconds to wait before aborting attempts to connect to the database.",
            "valueType": "number",
            "target": "jsonData",
            "validations": [
                {
                    "type": "range",
                    "min": 0
                }
            ]
        },
        {
            "id": "jsonData.enableSecureSocksProxy",
            "key": "enableSecureSocksProxy",
            "label": "Enable Secure Socks Proxy",
            "description": "Enables proxying the datasource connection through the secure socks proxy.",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.secureSocksProxyUsername",
            "key": "secureSocksProxyUsername",
            "label": "Secure Socks Proxy username",
            "description": "Username used to authenticate with the secure socks proxy.",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData.enableSecureSocksProxy == true"
        }
    ],
    "groups": [
        {
            "id": "connection",
            "title": "Connection",
            "fieldRefs": [
                "root.url",
                "jsonData.database"
            ]
        },
        {
            "id": "auth",
            "title": "Authentication",
            "fieldRefs": [
                "root.user",
                "secureJsonData.password",
                "jsonData.authenticationType",
                "jsonData.allowCleartextPasswords"
            ]
        },
        {
            "id": "tls",
            "title": "TLS/SSL Settings",
            "fieldRefs": [
                "jsonData.tlsSkipVerify",
                "jsonData.tlsConfigurationMethod",
                "jsonData.sslmode",
                "jsonData.encrypt",
                "jsonData.servername",
                "jsonData.sslRootCertFile",
                "jsonData.sslCertFile",
                "jsonData.sslKeyFile"
            ]
        },
        {
            "id": "mysql-options",
            "title": "MySQL Options",
            "fieldRefs": [
                "jsonData.timezone",
                "jsonData.timeInterval",
                "jsonData.timescaledb"
            ]
        },
        {
            "id": "connection-limits",
            "title": "Connection limits",
            "fieldRefs": [
                "jsonData.maxOpenConns",
                "jsonData.maxIdleConns",
                "jsonData.connMaxLifetime",
                "jsonData.connectionTimeout"
            ]
        },
        {
            "id": "proxy",
            "title": "Secure Socks Proxy",
            "fieldRefs": [
                "jsonData.enableSecureSocksProxy",
                "jsonData.secureSocksProxyUsername"
            ]
        }
    ]
}
